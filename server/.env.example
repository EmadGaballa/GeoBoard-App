# ======================================================
# GEOBOARD SERVER — ENVIRONMENT VARIABLES
# ======================================================

# --- Server ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/geoboard?connect_timeout=10&sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# --- Email (Resend) ---
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# --- External API Keys ---
# Weather: Open-Meteo is free, no key needed
# News: Webz.io
WEBZ_API_KEY=your_webz_api_key_here
# Currency: fawazahmed0/exchange-api is free, no key needed

# --- Redis Cache TTLs (in seconds) ---
CACHE_TTL_WEATHER=600
CACHE_TTL_NEWS=300
CACHE_TTL_CURRENCY=60
CACHE_TTL_LOCATION=3600

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Session ---
SESSION_SECRET=your_session_secret_here
